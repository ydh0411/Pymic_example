+def get_device(device_ids=None, device_name="auto"):
+    """Select a PyTorch device while keeping legacy ``gpus`` configs working."""
+    device_ids = [] if device_ids is None else device_ids
+    device_name = device_name.lower()
+    if device_name == "auto":
+        if torch.cuda.is_available() and len(device_ids) > 0:
+            return torch.device("cuda:{0:}".format(device_ids[0]))
+        if torch.backends.mps.is_available():
+            return torch.device("mps")
+        return torch.device("cpu")
+    if device_name == "cuda":
+        if not torch.cuda.is_available() or len(device_ids) == 0:
+            raise RuntimeError("CUDA was requested but no CUDA GPU is available")
+        return torch.device("cuda:{0:}".format(device_ids[0]))
+    if device_name == "mps":
+        if not torch.backends.mps.is_available():
+            raise RuntimeError("MPS was requested but is not available")
+        return torch.device("mps")
+    if device_name == "cpu":
+        return torch.device("cpu")
+    raise ValueError("device must be one of: auto, cuda, mps, cpu")
+
